{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/qiin2333/crown-profiles/main/schemas/crown-profile-index.v1.schema.json",
  "title": "Crown Profile Store Index",
  "type": "object",
  "required": ["kind", "schemaVersion", "profiles"],
  "properties": {
    "kind": {
      "const": "crown-profile-index"
    },
    "schemaVersion": {
      "const": 1
    },
    "generatedAt": {
      "type": "string"
    },
    "profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "url"],
        "properties": {
          "bundleId": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "game": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "updatedAt": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
